<!doctype html>
<html lang="cs">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>grandMA2 Sequence Content</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 0; background: #111827; color: #e5e7eb; }
    header { padding: 14px 20px; background: #0f172a; position: sticky; top: 0; z-index: 10; border-bottom: 1px solid #334155; }
    .header-brand { display:flex; gap:12px; align-items:center; margin-bottom:10px; }
    .header-brand img { width:min(170px, 28vw); max-width:100%; height:auto; object-fit:contain; border-radius:0; padding:0; background:none; border:none; box-shadow:0 6px 18px rgba(0,0,0,.18); }
    .header-copy { min-width:0; }
    .wrap { padding: 24px; }
    .card { background: #1f2937; border-radius: 16px; padding: 16px; box-shadow: 0 4px 20px rgba(0,0,0,.25); margin-bottom: 20px; }
    .muted { color: #94a3b8; font-size: 12px; }
    .topbar { display:flex; justify-content:space-between; align-items:flex-start; gap:10px; flex-wrap:wrap; }
    .nav-shell { display:grid; gap:8px; min-width:min(640px, 100%); }
    .category-nav, .page-nav { display:flex; gap:10px; flex-wrap:wrap; }
    .nav-pill, .page-nav button { padding: 8px 12px; border-radius: 999px; border: 1px solid #334155; background: #172033; color: #e5e7eb; text-decoration: none; cursor: pointer; font-size: 13px; }
    .nav-pill.active { background: rgba(56,189,248,.14); border-color: rgba(56,189,248,.45); color:#e0f2fe; }
    .nav-pill:hover, .page-nav button:hover { background: #22304b; }
    input, select { width: 100%; padding: 10px; border-radius: 10px; border: 1px solid #334155; background: #0f172a; color: #e5e7eb; }
    .layout { display:grid; grid-template-columns: 340px 1fr; gap: 20px; }
    @media (max-width: 1100px) { .layout { grid-template-columns: 1fr; } }
    .stats { display:grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap:12px; margin-top:16px; }
    .stat { background:#172033; border-radius:12px; padding:12px; }
    .cue-list { display:grid; gap:8px; margin-top:12px; max-height:44vh; overflow:auto; padding-right:4px; }
    .cue-list-item { width:100%; text-align:left; border:1px solid #334155; border-radius:12px; background:#0f172a; padding:10px 12px; color:#e5e7eb; cursor:pointer; }
    .cue-list-item:hover { background:#162033; border-color:#475569; }
    .cue-list-item.is-active { background:rgba(56,189,248,.12); border-color:rgba(56,189,248,.48); box-shadow: inset 0 0 0 1px rgba(56,189,248,.18); }
    .cue-list-head { display:flex; align-items:center; justify-content:space-between; gap:10px; }
    .cue-list-title { font-size:12px; font-weight:800; color:#f8fafc; }
    .cue-list-name { margin-top:4px; font-size:12px; color:#cbd5e1; line-height:1.35; }
    .cue-list-meta { margin-top:8px; display:flex; gap:6px; flex-wrap:wrap; }
    .sequence-content-controls { display:flex; gap:14px; flex-wrap:wrap; align-items:center; margin-top:12px; }
    .sequence-content-controls label { display:inline-flex; gap:8px; align-items:center; color:#cbd5e1; font-size:12px; }
    .sequence-content-controls input[type="checkbox"] { width:auto; margin:0; }
    .table-wrap { overflow:auto; max-height: 76vh; border:1px solid #334155; border-radius:12px; }
    table { width: 100%; border-collapse: separate; border-spacing: 0; }
    th, td { text-align: left; border-bottom: 1px solid #334155; padding: 8px; vertical-align: top; }
    th { position: sticky; top: 0; z-index: 3; background: #172033; }
    .sequence-content-table { min-width: 1600px; }
    .sequence-content-table th:first-child, .sequence-content-table td:first-child { position: sticky; left: 0; z-index: 2; background: #172033; }
    .sequence-content-table th:nth-child(2), .sequence-content-table td:nth-child(2) { position: sticky; left: 110px; z-index: 2; background: #1f2937; }
    .sequence-content-table th:first-child, .sequence-content-table th:nth-child(2) { z-index: 4; }
    .seq-id-cell { width: 90px; min-width: 90px; font-weight: 800; }
    .seq-fixture-cell { min-width: 270px; }
    .seq-fixture-title { font-weight: 800; color:#f8fafc; }
    .seq-fixture-meta { margin-top: 4px; font-size: 11px; color:#94a3b8; line-height: 1.35; }
    .seq-fixture-badges { display:flex; flex-wrap:wrap; gap:6px; margin-top:8px; }
    .seq-fixture-badge { display:inline-flex; align-items:center; justify-content:center; min-height:20px; padding:0 8px; border-radius:999px; font-size:10px; font-weight:800; letter-spacing:.03em; }
    .seq-fixture-badge.is-hard { background:#7f1d1d; color:#fecaca; border:1px solid #fecaca; }
    .seq-fixture-badge.is-dimmer { background:#f59e0b; color:#1f2937; border:1px solid #fdba74; }
    .seq-family-cell { min-width: 180px; vertical-align: top; }
    .seq-family-block { display:grid; gap:6px; }
    .seq-family-group { border:1px solid #334155; border-radius:10px; padding:6px 8px; background:#0f172a; }
    .seq-family-group.is-hard { border-color:#7f1d1d; background:rgba(127,29,29,.12); }
    .seq-family-group.is-dimmer { border-color:#b45309; background:rgba(180,83,9,.15); }
    .seq-family-group.is-preset { border-color:#082f49; background:rgba(8,47,73,.18); }
    .seq-family-label { display:flex; align-items:center; gap:6px; margin-bottom:4px; font-size:11px; font-weight:700; color:#cbd5e1; }
    .seq-family-lines { display:grid; gap:4px; }
    .seq-family-line { font-size:11px; line-height:1.35; color:#e5e7eb; }
    .seq-family-empty { color:#475569; font-size:11px; }
    .seq-mode-cell { min-width: 160px; }
    .seq-preset-cell { min-width: 220px; }
    .pill { display: inline-block; padding: 2px 8px; background: #334155; border-radius: 999px; margin: 2px; font-size: 12px; }
    .pill-hard { background:#7f1d1d; color:#fecaca; font-weight:700; }
    .pill-dimmer { background:#b45309; color:#ffedd5; font-weight:700; }
    .pill-preset { background:#082f49; color:#bae6fd; font-weight:700; }
    .pill-mixed { background:#78350f; color:#fde68a; font-weight:700; }
    .pill-neutral { background:#334155; color:#e5e7eb; font-weight:700; }
    .pre { white-space: pre-wrap; word-break: break-word; }
    @media print {
      body { background: #fff; color: #000; }
      header, .controls-print-hide { display: none !important; }
      .wrap { padding: 0; }
      .card { box-shadow: none; border: 1px solid #ccc; background: #fff; color: #000; }
      th, td { border-bottom: 1px solid #ccc; color: #000; }
      th { background: #f1f5f9; }
      .layout { display:block; }
      .table-wrap { max-height: none; overflow: visible; border: none; }
    }
  </style>
  <link rel="stylesheet" href="app_shell.css">
</head>
